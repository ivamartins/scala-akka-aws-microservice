{
  "family": "akka-orders-dev",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/akka-orders-dev-ecs-exec",
  "taskRoleArn":      "arn:aws:iam::ACCOUNT_ID:role/akka-orders-dev-task",
  "containerDefinitions": [
    {
      "name": "akka-orders-dev",
      "image": "PLACEHOLDER",
      "essential": true,
      "portMappings": [{ "containerPort": 8080, "hostPort": 8080, "protocol": "tcp" }],
      "environment": [
        { "name": "PORT",            "value": "8080" },
        { "name": "STORAGE_BACKEND", "value": "dynamodb" },
        { "name": "DYNAMODB_TABLE",  "value": "akka-orders-dev-orders" },
        { "name": "AWS_REGION",      "value": "us-east-1" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/akka-orders-dev",
          "awslogs-region":        "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
